<component>
  <api>
    <prop name="slot_index" type="int" default="0"/>
  </api>
  <consts>
    <!-- Dropdown width responsive to breakpoint: narrower at MICRO/TINY so the
         leading label/icon isn't obscured when the menu is content-sized. -->
    <px name="ams_context_dropdown_w_micro" value="80"/>
    <px name="ams_context_dropdown_w_tiny" value="90"/>
    <px name="ams_context_dropdown_w_small" value="110"/>
    <px name="ams_context_dropdown_w_medium" value="110"/>
    <px name="ams_context_dropdown_w_large" value="110"/>
  </consts>
  <!-- Full-screen backdrop overlay - tap to dismiss -->
  <view name="context_backdrop"
        extends="lv_obj" width="100%" height="100%" style_bg_opa="128" style_bg_color="0x000000" style_border_width="0"
        style_pad_all="0" style_radius="0" clickable="true">
    <event_cb trigger="clicked" callback="ams_context_backdrop_cb"/>
    <!-- Context menu card - positioned by C++ -->
    <lv_obj name="context_menu"
            width="content" height="content" style_bg_color="#elevated_bg" style_bg_opa="255" style_radius="#border_radius"
            style_pad_all="#space_sm" style_pad_gap="#space_md" flex_flow="column" style_flex_main_place="start"
            scrollable="false" clickable="true">
      <!-- Header: "Slot N" -->
      <text_body name="slot_header" text="Slot 1" translation_tag="Slot 1"/>
      <!-- Header Divider -->
      <lv_obj width="100%"
              height="1" style_bg_color="#text_muted" style_bg_opa="38" style_pad_all="0" scrollable="false"/>
      <!-- Load Button -->
      <ui_button name="btn_load"
                 height="#button_height_sm" icon="z_closer" text="Load" translation_tag="Load"
                 variant="ghost" clickable="true" style_flex_main_place="start">
        <bind_state_if_eq subject="ams_slot_can_load" state="disabled" ref_value="0"/>
        <event_cb trigger="clicked" callback="ams_context_load_cb"/>
      </ui_button>
      <!-- Unload Button (disabled when slot is not loaded) -->
      <ui_button name="btn_unload"
                 height="#button_height_sm" icon="z_farther" text="Unload" translation_tag="Unload"
                 variant="ghost" clickable="true" style_flex_main_place="start">
        <bind_state_if_eq subject="ams_slot_is_loaded" state="disabled" ref_value="0"/>
        <event_cb trigger="clicked" callback="ams_context_unload_cb"/>
      </ui_button>
      <!-- Reset Lane Button (hidden unless backend supports it) -->
      <ui_button name="btn_reset_lane"
                 height="#button_height_sm" icon="refresh" text="Reset" translation_tag="Reset"
                 variant="ghost" clickable="true" style_flex_main_place="start" hidden="true">
        <event_cb trigger="clicked" callback="ams_context_reset_lane_cb"/>
      </ui_button>
      <!-- Select Gate Button (hidden unless backend supports gate select, e.g. Happy Hare) -->
      <ui_button name="btn_gate_select"
                 height="#button_height_sm" icon="target" text="Select gate" translation_tag="Select gate"
                 variant="ghost" clickable="true" style_flex_main_place="start" hidden="true">
        <event_cb trigger="clicked" callback="ams_context_gate_select_cb"/>
      </ui_button>
      <!-- Check Gate Button (hidden unless backend supports gate check, e.g. Happy Hare) -->
      <ui_button name="btn_gate_check"
                 height="#button_height_sm" icon="refresh" text="Check this gate" translation_tag="Check gate"
                 variant="ghost" clickable="true" style_flex_main_place="start" hidden="true">
        <event_cb trigger="clicked" callback="ams_context_gate_check_cb"/>
      </ui_button>
      <!-- Select Spool Button (Spoolman quick-assign, hidden by default) -->
      <ui_button name="btn_spoolman"
                 height="#button_height_sm" icon="spoolman" text="Select Spool"
                 translation_tag="Select Spool" variant="ghost" clickable="true" style_flex_main_place="start"
                 hidden="true">
        <event_cb trigger="clicked" callback="ams_context_spoolman_cb"/>
      </ui_button>
      <!-- Scan QR Code Button (hidden by default, shown when Spoolman enabled) -->
      <ui_button name="btn_scan_qr"
                 height="#button_height_sm" icon="qrcode_scan" text="Scan QR Code"
                 translation_tag="Scan QR Code" variant="ghost" clickable="true" style_flex_main_place="start"
                 hidden="true">
        <event_cb trigger="clicked" callback="ams_context_scan_qr_cb"/>
      </ui_button>
      <!-- Spool Info Button — always opens edit modal -->
      <ui_button name="btn_edit"
                 height="#button_height_sm" icon="tune" text="Spool Info" translation_tag="Spool Info"
                 variant="ghost" clickable="true" style_flex_main_place="start">
        <event_cb trigger="clicked" callback="ams_context_edit_cb"/>
      </ui_button>
      <!-- Clear Spool Button — shown only when the slot has a Spoolman assignment -->
      <ui_button name="btn_clear_spool"
                 height="#button_height_sm" icon="close" text="Clear Spool" translation_tag="Clear Spool"
                 variant="ghost" clickable="true" style_flex_main_place="start" hidden="true">
        <event_cb trigger="clicked" callback="ams_context_clear_spool_cb"/>
      </ui_button>
      <!-- Divider before dropdowns -->
      <lv_obj name="dropdown_divider"
              width="100%" height="1" style_bg_color="#text_muted" style_bg_opa="38" style_pad_all="0"
              style_margin_top="#space_xs" style_margin_bottom="#space_xs" scrollable="false" hidden="true"/>
      <!-- Tool Mapping Dropdown -->
      <lv_obj name="tool_dropdown_row"
              width="100%" height="content" style_pad_all="0" style_pad_left="#space_sm" style_pad_right="#space_sm"
              flex_flow="row" style_flex_main_place="space_between" style_flex_cross_place="center" scrollable="false"
              hidden="true">
        <text_small text="Tool" translation_tag="Tool"/>
        <lv_dropdown name="tool_dropdown" width="#ams_context_dropdown_w" height="#button_height_sm" style_radius="#border_radius" style_border_width="0">
          <event_cb trigger="value_changed" callback="ams_context_tool_changed_cb"/>
        </lv_dropdown>
      </lv_obj>
      <!-- Backup Slot Dropdown (Endless Spool) -->
      <lv_obj name="backup_dropdown_row"
              width="100%" height="content" style_pad_all="0" style_pad_left="#space_sm" style_pad_right="#space_sm"
              flex_flow="row" style_flex_main_place="space_between" style_flex_cross_place="center" scrollable="false"
              hidden="true">
        <lv_label name="backup_icon" text="#icon_infinity" style_text_font="mdi_icons_16" style_text_color="#text_muted"/>
        <lv_dropdown name="backup_dropdown" width="#ams_context_dropdown_w" height="#button_height_sm" style_radius="#border_radius" style_border_width="0">
          <event_cb trigger="value_changed" callback="ams_context_backup_changed_cb"/>
        </lv_dropdown>
      </lv_obj>
    </lv_obj>
  </view>
</component>
