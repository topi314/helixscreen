<component>
  <!-- Full-screen backdrop overlay - tap to dismiss -->
  <view name="selector_backdrop"
        extends="lv_obj" width="100%" height="100%" style_bg_opa="128" style_bg_color="0x000000" style_border_width="0"
        style_pad_all="0" style_radius="0" clickable="true">
    <event_cb trigger="clicked" callback="ams_selector_backdrop_cb"/>
    <!-- Selector context menu card - positioned by C++ -->
    <lv_obj name="selector_menu"
            width="content" height="content" style_bg_color="#elevated_bg" style_bg_opa="255" style_radius="#border_radius"
            style_pad_all="#space_sm" style_pad_gap="#space_xs" flex_flow="column" style_flex_main_place="start"
            scrollable="false" clickable="true">
      <!-- Header -->
      <text_small name="menu_header" text="Selector" translation_tag="Selector"/>
      <!-- Header Divider -->
      <lv_obj width="100%"
              height="1" style_bg_color="#text_muted" style_bg_opa="38" style_pad_all="0" scrollable="false"/>
      <!-- Home selector -->
      <ui_button name="btn_home_selector"
                 height="#button_height_sm" icon="home" text="Home selector" translation_tag="Home selector"
                 variant="ghost" clickable="true" style_flex_main_place="start">
        <event_cb trigger="clicked" callback="ams_selector_home_cb"/>
      </ui_button>
      <!-- Check slots -->
      <ui_button name="btn_check_slots"
                 height="#button_height_sm" icon="refresh" text="Check slots" translation_tag="Check slots"
                 variant="ghost" clickable="true" style_flex_main_place="start">
        <event_cb trigger="clicked" callback="ams_selector_check_cb"/>
      </ui_button>
      <!-- Servo row (hidden on Type B / virtual selector) -->
      <!-- Servo row sizes to content (Servo label + 3 natural-width buttons); as
           the widest row it drives the card's content width, so the menu scales
           with font/button size per resolution instead of a hardcoded width. -->
      <lv_obj name="servo_row"
              width="content" height="content" style_pad_all="0" style_pad_gap="#space_xs"
              flex_flow="row" style_flex_cross_place="center" scrollable="false">
        <text_small text="Servo" translation_tag="Servo"/>
        <ui_button name="btn_servo_up"
                   height="#button_height_sm" text="Up" translation_tag="Up" variant="secondary" clickable="true">
          <event_cb trigger="clicked" callback="ams_selector_servo_up_cb"/>
        </ui_button>
        <ui_button name="btn_servo_move"
                   height="#button_height_sm" text="Move" translation_tag="Move" variant="secondary" clickable="true">
          <event_cb trigger="clicked" callback="ams_selector_servo_move_cb"/>
        </ui_button>
        <ui_button name="btn_servo_down"
                   height="#button_height_sm" text="Down" translation_tag="Down" variant="secondary" clickable="true">
          <event_cb trigger="clicked" callback="ams_selector_servo_down_cb"/>
        </ui_button>
      </lv_obj>
      <!-- Jog (move selector) row -->
      <lv_obj name="jog_row"
              width="100%" height="content" style_pad_all="0" style_pad_gap="#space_xs"
              flex_flow="row" style_flex_cross_place="center" scrollable="false">
        <text_small text="Move selector" translation_tag="Move selector" flex_grow="1"/>
        <ui_button name="btn_jog_prev"
                   height="#button_height_sm" icon="chevron_left" variant="secondary" clickable="true">
          <event_cb trigger="clicked" callback="ams_selector_jog_prev_cb"/>
        </ui_button>
        <ui_button name="btn_jog_next"
                   height="#button_height_sm" icon="chevron_right" variant="secondary" clickable="true">
          <event_cb trigger="clicked" callback="ams_selector_jog_next_cb"/>
        </ui_button>
      </lv_obj>
      <!-- Gear motor sync toggle row -->
      <lv_obj name="gear_sync_row"
              width="100%" height="content" style_pad_all="0" style_pad_gap="#space_sm"
              flex_flow="row" style_flex_main_place="space_between" style_flex_cross_place="center" scrollable="false">
        <text_body text="Gear motor synced" translation_tag="Gear motor synced"/>
        <ui_switch name="gear_sync_switch" size="small">
          <event_cb trigger="value_changed" callback="ams_selector_gear_sync_cb"/>
        </ui_switch>
      </lv_obj>
      <!-- Recover -->
      <ui_button name="btn_recover"
                 height="#button_height_sm" icon="restart" text="Recover" translation_tag="Recover"
                 variant="ghost" clickable="true" style_flex_main_place="start">
        <event_cb trigger="clicked" callback="ams_selector_recover_cb"/>
      </ui_button>
    </lv_obj>
  </view>
</component>
