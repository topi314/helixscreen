<!-- About Settings Overlay Panel -->
<!-- Shows branding, version info, update controls, and system details -->
<component>
  <view name="about_settings_overlay"
        extends="overlay_panel" width="#overlay_panel_width_full" title="About" title_tag="About"
        bg_color="#screen_bg">
    <!-- Content Area -->
    <lv_obj name="overlay_content"
            width="100%" flex_grow="1" style_pad_top="0" style_pad_left="#space_lg" style_pad_right="#space_lg"
            style_pad_bottom="#space_lg" scrollable="true" flex_flow="column">
      <!-- ================================================================== -->
      <!-- BRANDING HEADER -->
      <!-- ================================================================== -->
      <lv_obj width="100%"
              height="content" flex_flow="column" style_flex_main_place="center" style_flex_cross_place="center"
              style_pad_top="0" style_pad_bottom="#space_md" style_pad_left="0" style_pad_right="0"
              style_pad_gap="#space_xs" scrollable="false">
        <lv_image src="A:assets/images/about-logo.bin" align="center"
                  width="120" height="content" inner_align="contain"/>
        <text_body text="by Preston Brown" style_text_align="center" width="100%"/>
        <text_small name="copyright_text" bind_text="about_copyright" style_text_color="#text_muted" style_text_align="center" width="100%"/>
        <!-- Scrolling contributor marquee (populated by C++) -->
        <!-- Max width ensures the text always overflows and triggers scroll animation,
             even on wide screens (1024px+) where the full text might fit at 100%. -->
        <lv_obj name="contributor_marquee"
                width="80%" height="content" style_pad_all="0" style_pad_gap="0" style_bg_opa="0" style_border_width="0"
                scrollable="false" style_clip_corner="true" overflow="hidden"/>
      </lv_obj>
      <!-- Printer Name (7-tap easter egg trigger) -->
      <ui_button name="row_printer" width="100%" height="content" variant="ghost" style_radius="0" style_pad_all="0">
        <lv_obj width="100%"
                height="content" flex_flow="row" style_flex_main_place="start" style_flex_cross_place="center"
                style_pad_left="#space_lg" style_pad_right="#space_lg" style_pad_top="#space_md"
                style_pad_bottom="#space_md" style_pad_gap="#space_sm" scrollable="false" clickable="false"
                event_bubble="true">
          <icon name="row_icon" src="printer_3d" size="sm" variant="secondary" clickable="false" event_bubble="true"/>
          <text_body name="label"
                     text="Printer Name" translation_tag="Printer Name" style_text_color="#text" flex_grow="1"
                     clickable="false" event_bubble="true"/>
          <text_muted name="value" bind_text="printer_value" clickable="false" event_bubble="true"/>
        </lv_obj>
        <event_cb trigger="clicked" callback="on_about_printer_name_clicked"/>
      </ui_button>
      <!-- Current Version - ui_button for native press feedback (7-tap secret to toggle beta features) -->
      <ui_button name="row_version" width="100%" height="content" variant="ghost" style_radius="0" style_pad_all="0">
        <lv_obj width="100%"
                height="content" flex_flow="row" style_flex_main_place="start" style_flex_cross_place="center"
                style_pad_left="#space_lg" style_pad_right="#space_lg" style_pad_top="#space_md"
                style_pad_bottom="#space_md" style_pad_gap="#space_sm" scrollable="false" clickable="false"
                event_bubble="true">
          <icon name="row_icon" src="info" size="sm" variant="secondary" clickable="false" event_bubble="true"/>
          <text_body name="label"
                     text="Current Version" translation_tag="Current Version" style_text_color="#text" flex_grow="1"
                     clickable="false" event_bubble="true"/>
          <text_muted name="value" bind_text="version_value" clickable="false" event_bubble="true"/>
        </lv_obj>
        <event_cb trigger="clicked" callback="on_about_version_clicked"/>
      </ui_button>
      <!-- Update Channel (gated by beta_features) -->
      <lv_obj name="container_update_channel" width="100%" style_pad_all="0">
        <bind_flag_if_eq subject="show_beta_features" flag="hidden" ref_value="0"/>
        <setting_dropdown_row name="row_update_channel"
                              label="Update Channel" label_tag="Update Channel" icon="swap_vertical"
                              options="Stable&#10;Beta&#10;Dev" options_tag="Stable&#10;Beta&#10;Dev" bind_selected="update_channel"
                              hide_description="true" callback="on_about_update_channel_changed"/>
      </lv_obj>
      <!-- Check for Updates (reactive description shows available version) -->
      <lv_obj name="container_check_updates" width="100%" style_pad_all="0" scrollable="false">
        <bind_flag_if_eq subject="show_update_settings" flag="hidden" ref_value="0"/>
        <setting_action_row name="row_check_updates"
                            label="Check for Updates" label_tag="Check for Updates" icon="refresh"
                            bind_description="update_version_text" description_min_bp="0"
                            callback="on_about_check_updates_clicked"/>
      </lv_obj>
      <!-- Install Update (visible only when update available) -->
      <lv_obj name="container_install_update" width="100%" style_pad_all="0">
        <bind_flag_if_eq subject="show_update_settings" flag="hidden" ref_value="0"/>
        <bind_flag_if_not_eq subject="update_status" flag="hidden" ref_value="2"/>
        <setting_action_row name="row_install_update"
                            label="Install Update" label_tag="Install Update" icon="download" description=""
                            description_tag="" callback="on_about_install_update_clicked"/>
      </lv_obj>
      <!-- Klipper Version -->
      <setting_info_row name="row_klipper" label="Klipper" label_tag="Klipper" icon="toy_brick_outline">
        <text_muted name="value" bind_text="klipper_version"/>
      </setting_info_row>
      <!-- Moonraker Version -->
      <setting_info_row name="row_moonraker" label="Moonraker" label_tag="Moonraker" icon="toy_brick_outline">
        <text_muted name="value" bind_text="moonraker_version"/>
      </setting_info_row>
      <!-- OS Version -->
      <setting_info_row name="row_os" label="OS" label_tag="OS" icon="console">
        <text_muted name="value" bind_text="os_version"/>
      </setting_info_row>
      <!-- Install Root (hidden on Android — SDL-sandboxed paths are not user-meaningful) -->
      <lv_obj name="container_install_root" width="100%" style_pad_all="0" scrollable="false">
        <bind_flag_if_eq subject="settings_is_android" flag="hidden" ref_value="1"/>
        <setting_info_row name="row_install_root"
                          label="Install Root" label_tag="Install Root"
                          icon="folder_home">
          <text_muted name="value" bind_text="install_root_value"/>
        </setting_info_row>
      </lv_obj>
      <!-- Config Dir (hidden on Android) -->
      <lv_obj name="container_config_dir" width="100%" style_pad_all="0" scrollable="false">
        <bind_flag_if_eq subject="settings_is_android" flag="hidden" ref_value="1"/>
        <setting_info_row name="row_config_dir"
                          label="Config Dir" label_tag="Config Dir"
                          icon="cog">
          <text_muted name="value" bind_text="config_dir_value"/>
        </setting_info_row>
      </lv_obj>
      <!-- Cache Dir (hidden on Android) -->
      <lv_obj name="container_cache_dir" width="100%" style_pad_all="0" scrollable="false">
        <bind_flag_if_eq subject="settings_is_android" flag="hidden" ref_value="1"/>
        <setting_info_row name="row_cache_dir"
                          label="Cache Dir" label_tag="Cache Dir"
                          icon="database">
          <text_muted name="value" bind_text="cache_dir_value"/>
        </setting_info_row>
      </lv_obj>
      <!-- Total Print Hours (opens history dashboard) -->
      <setting_action_row name="row_print_hours"
                          label="Print Hours" label_tag="Print Hours" icon="clock" bind_description="print_hours_value"
                          callback="on_about_print_hours_clicked"/>
      <!-- ================================================================== -->
      <!-- OPEN SOURCE LICENSES -->
      <!-- ================================================================== -->
      <lv_obj width="100%"
              height="content" flex_flow="column" style_pad_top="#space_lg" style_pad_bottom="0"
              style_pad_left="0" style_pad_right="0" style_pad_gap="#space_xs" scrollable="false">
        <text_small text="Open Source Licenses" translation_tag="Open Source Licenses"
                    style_text_color="#text_muted" style_text_align="center" width="100%"/>
        <lv_obj width="100%"
                height="content" style_pad_all="#space_md" style_bg_color="#card_bg" style_bg_opa="255"
                style_radius="#border_radius" scrollable="false">
          <text_tiny name="licenses_text"
                     width="100%" style_text_color="#text_muted" style_text_line_space="4"
                     text="HelixScreen — GPL-3.0&#10;LVGL — MIT License&#10;helix-xml — MIT License&#10;libhv — BSD 3-Clause License&#10;spdlog — MIT License&#10;nlohmann/json — MIT License&#10;SDL2 — zlib License&#10;Expat — MIT License&#10;md4c — MIT License&#10;ThorVG — MIT License&#10;GLM — MIT License&#10;quirc — ISC License&#10;lv_i18n — MIT License&#10;lv_markdown — MIT License&#10;stb — Public Domain&#10;mdns — Public Domain&#10;picosha2 — MIT License&#10;OpenVDB — Apache 2.0 License&#10;libnl — LGPL 2.1&#10;minilzo — GPL 2.0&#10;ftxui — MIT License&#10;cpp-terminal — MIT License&#10;wpa_supplicant — BSD 3-Clause License"/>
        </lv_obj>
      </lv_obj>
      <!-- Credits -->
      <text_tiny text="Space Debris mod by Markus 'Captain' Kaarlonen"
                 style_text_color="#text_muted" style_text_align="center" width="100%"
                 style_pad_top="#space_sm"/>
      <!-- Bottom padding for scroll -->
      <lv_obj width="100%" height="#space_lg" scrollable="false"/>
    </lv_obj>
  </view>
</component>
