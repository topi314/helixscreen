<component>
  <consts>
    <!-- Stroke thickness — responsive per breakpoint. Overall arc diameter
         is computed dynamically in C++ from the arc_holder dimensions; the
         XML width/height are placeholders that C++ overrides. -->
    <px name="progress_arc_thickness_tiny"    value="6"/>
    <px name="progress_arc_thickness_small"   value="7"/>
    <px name="progress_arc_thickness_medium"  value="8"/>
    <px name="progress_arc_thickness_large"   value="9"/>
    <px name="progress_arc_thickness_xlarge"  value="10"/>
    <px name="progress_arc_thickness_xxlarge" value="12"/>
  </consts>
  <view name="print_status_detailed_active" extends="lv_obj"
        width="100%" height="100%" style_pad_all="0" style_pad_gap="#space_xs"
        flex_flow="column" scrollable="false" clickable="false" event_bubble="true">
    <!-- Main row: thumb | arc | data -->
    <lv_obj name="detailed_main_row"
            width="100%" flex_grow="1" style_pad_all="0" flex_flow="row"
            style_pad_column="#space_md" style_flex_cross_place="center"
            scrollable="false" clickable="false" event_bubble="true">
      <lv_image name="detailed_thumb"
                flex_grow="2" height="100%" src="A:assets/images/benchy_thumbnail_white.png"
                bind_src="print_thumbnail_path"
                inner_align="contain" clickable="false" event_bubble="true"/>
      <lv_obj name="detailed_center_col"
              flex_grow="2" height="100%" style_pad_all="0" flex_flow="column"
              style_flex_cross_place="center" style_pad_gap="0"
              scrollable="false" clickable="false" event_bubble="true">
        <!-- Arc holder: flex_grow=1 fills column; arc + % are siblings at
             align="center" (fan_arc_core.xml pattern). C++ resize_arc_to_square
             reads this holder's dimensions and sizes the arc square. -->
        <lv_obj name="detailed_arc_holder"
                width="100%" flex_grow="1" style_pad_all="0"
                scrollable="false" clickable="false" event_bubble="true">
          <lv_arc name="detailed_progress_arc" align="center"
                  width="80" height="80" style_pad_all="0"
                  min_value="0" max_value="100" value="0"
                  bg_start_angle="135" bg_end_angle="45"
                  start_angle="135" end_angle="135"
                  rotation="0" mode="normal"
                  style_arc_color="#border" style_arc_color-indicator="#primary"
                  style_arc_width="#progress_arc_thickness_medium"
                  style_arc_width-indicator="#progress_arc_thickness_medium"
                  style_arc_rounded="true" style_arc_rounded-indicator="true"
                  style_bg_opa="0" style_border_width="0"
                  style_bg_opa-knob="0" style_shadow_width-knob="0"
                  style_outline_width-knob="0" style_pad_all-knob="0"
                  clickable="false" event_bubble="true"/>
          <text_body name="detailed_progress_pct" align="center"
                     bind_text="print_status_progress_pct" clickable="false" event_bubble="true"/>
        </lv_obj>
      </lv_obj>
      <lv_obj name="detailed_data_col"
              flex_grow="3" height="100%" style_pad_all="0" flex_flow="column"
              style_flex_main_place="center" style_flex_cross_place="start"
              style_pad_row="#space_xs"
              scrollable="false" clickable="false" event_bubble="true">
        <text_body name="detailed_filename" width="100%"
                   bind_text="print_display_filename" long_mode="scroll_circular"
                   clickable="false" event_bubble="true"/>
        <text_small bind_text="print_status_layer_text" clickable="false" event_bubble="true"/>
        <text_small bind_text="print_status_time_text" clickable="false" event_bubble="true"/>
        <text_small bind_text="print_status_filament_text" clickable="false" event_bubble="true">
          <bind_flag_if_eq subject="print_status_show_filament_active" flag="hidden" ref_value="0"/>
        </text_small>
      </lv_obj>
    </lv_obj>
    <!-- Temps: always a full-width row at the bottom of the card. Uses the
         standard temp_display widget so heating-color logic (red=heating up,
         blue=cooling, etc.) matches the rest of the app — DRY with
         panel_widget_temp_stack.xml and controls_panel.xml. -->
    <lv_obj name="detailed_temp_row"
            width="100%" height="content" style_pad_all="0" flex_flow="row"
            style_pad_gap="#space_sm" style_flex_main_place="space_evenly"
            style_flex_cross_place="center"
            scrollable="false" clickable="false" event_bubble="true">
      <lv_obj width="content" height="content" style_pad_all="0" flex_flow="row"
              style_pad_gap="#space_xs" style_flex_cross_place="center"
              scrollable="false" clickable="false" event_bubble="true">
        <text_small bind_text="print_status_nozzle_tool_label" clickable="false" event_bubble="true">
          <bind_flag_if_eq subject="print_status_multi_tool" flag="hidden" ref_value="0"/>
        </text_small>
        <nozzle_icon size="sm" badge_subject="" clickable="false" event_bubble="true"/>
        <!-- Bound to formatter-driven proxy subjects so pinning to a specific tool
             (via the chevron picker) actually changes the displayed temperature.
             The formatter rebinds its underlying observer on pin change. -->
        <temp_display size="xs" show_target="true"
                      bind_current="print_status_nozzle_current"
                      bind_target="print_status_nozzle_target"
                      clickable="false" event_bubble="true"/>
        <icon src="chevron_down" size="sm">
          <bind_flag_if_eq subject="print_status_multi_tool" flag="hidden" ref_value="0"/>
          <event_cb trigger="clicked" callback="print_status_nozzle_chevron_cb"/>
        </icon>
      </lv_obj>
      <lv_obj width="content" height="content" style_pad_all="0" flex_flow="row"
              style_pad_gap="#space_xs" style_flex_cross_place="center"
              scrollable="false" clickable="false" event_bubble="true">
        <icon src="radiator" size="sm" variant="secondary" clickable="false" event_bubble="true"/>
        <temp_display size="xs" show_target="true"
                      bind_current="bed_temp" bind_target="bed_target"
                      clickable="false" event_bubble="true"/>
      </lv_obj>
      <lv_obj width="content" height="content" style_pad_all="0" flex_flow="row"
              style_pad_gap="#space_xs" style_flex_cross_place="center"
              scrollable="false" clickable="false" event_bubble="true">
        <bind_flag_if_eq subject="printer_has_chamber" flag="hidden" ref_value="0"/>
        <icon src="fridge_industrial" size="sm" variant="secondary" clickable="false" event_bubble="true"/>
        <!-- Two variants: with target when a chamber heater exists, current-only
             for sensor-only chambers (passive enclosure). Mutually exclusive on
             printer_has_chamber_heater. -->
        <temp_display size="xs" show_target="true"
                      bind_current="chamber_temp" bind_target="chamber_target"
                      clickable="false" event_bubble="true">
          <bind_flag_if_eq subject="printer_has_chamber_heater" flag="hidden" ref_value="0"/>
        </temp_display>
        <temp_display size="xs" show_target="false"
                      bind_current="chamber_temp"
                      clickable="false" event_bubble="true">
          <bind_flag_if_eq subject="printer_has_chamber_heater" flag="hidden" ref_value="1"/>
        </temp_display>
      </lv_obj>
    </lv_obj>
    <!-- M117 footer -->
    <text_small name="detailed_active_display_message" width="100%"
                bind_text="display_message" style_text_align="center" long_mode="dots"
                hidden="true" clickable="false" event_bubble="true">
      <bind_flag_if_eq subject="display_message_visible" flag="hidden" ref_value="0"/>
    </text_small>
  </view>
</component>
