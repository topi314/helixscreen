<component>
  <!-- Reusable temp-cell components -->
  <view name="nozzle_temp_block" extends="lv_obj"
        width="content" height="content" style_pad_all="0" flex_flow="row"
        style_pad_gap="#space_xxs" style_flex_cross_place="center"
        scrollable="false" clickable="false" event_bubble="true">
    <text_small bind_text="print_status_nozzle_tool_label" clickable="false" event_bubble="true">
      <bind_flag_if_eq subject="print_status_multi_tool" flag="hidden" ref_value="0"/>
    </text_small>
    <icon src="printer_3d_nozzle" size="sm" clickable="false" event_bubble="true"/>
    <text_small bind_text="print_status_nozzle_text" clickable="false" event_bubble="true"/>
    <icon name="detailed_tool_chevron" src="chevron_down" size="sm">
      <bind_flag_if_eq subject="print_status_multi_tool" flag="hidden" ref_value="0"/>
      <event_cb trigger="clicked" callback="print_status_nozzle_chevron_cb"/>
    </icon>
  </view>

  <view name="bed_temp_block" extends="lv_obj"
        width="content" height="content" style_pad_all="0" flex_flow="row"
        style_pad_gap="#space_xxs" style_flex_cross_place="center"
        scrollable="false" clickable="false" event_bubble="true">
    <icon src="bed" size="sm" clickable="false" event_bubble="true"/>
    <text_small bind_text="print_status_bed_text" clickable="false" event_bubble="true"/>
  </view>

  <view name="chamber_temp_block" extends="lv_obj"
        width="content" height="content" style_pad_all="0" flex_flow="row"
        style_pad_gap="#space_xxs" style_flex_cross_place="center"
        scrollable="false" clickable="false" event_bubble="true">
    <bind_flag_if_eq subject="printer_has_chamber" flag="hidden" ref_value="0"/>
    <icon src="fridge_industrial" size="sm" clickable="false" event_bubble="true"/>
    <text_small bind_text="print_status_chamber_text" clickable="false" event_bubble="true"/>
  </view>

  <!-- Active print Detailed body -->
  <view name="print_status_detailed_active" extends="lv_obj"
        width="100%" height="100%" style_pad_all="0" style_pad_gap="#space_xs"
        flex_flow="column" scrollable="false" clickable="false" event_bubble="true">
    <!-- Main row: thumb | arc | data -->
    <lv_obj name="detailed_main_row"
            width="100%" flex_grow="1" style_pad_all="0" flex_flow="row" style_pad_gap="#space_sm"
            style_flex_cross_place="center" scrollable="false" clickable="false" event_bubble="true">
      <lv_image name="detailed_thumb"
                width="35%" height="100%" src="A:assets/images/benchy_thumbnail_white.png"
                inner_align="contain" clickable="false" event_bubble="true"/>
      <lv_obj name="detailed_center_col"
              width="content" height="100%" style_pad_all="0" flex_flow="column"
              style_flex_main_place="center" style_flex_cross_place="center"
              style_pad_gap="#space_xxs" scrollable="false" clickable="false" event_bubble="true">
        <lv_obj name="detailed_arc_container"
                width="80" height="80" style_pad_all="0"
                scrollable="false" clickable="false" event_bubble="true">
          <lv_arc name="detailed_progress_arc"
                  align="center" width="80" height="80" style_pad_all="0"
                  min_value="0" max_value="100" value="0"
                  bg_start_angle="135" bg_end_angle="45"
                  rotation="0" mode="normal"
                  style_arc_color="#border" style_arc_color-indicator="#primary"
                  style_arc_rounded="true" style_arc_rounded-indicator="true"
                  style_bg_opa="0" style_border_width="0"
                  style_bg_opa-knob="0" style_shadow_width-knob="0"
                  style_outline_width-knob="0" style_pad_all-knob="0"
                  clickable="false" event_bubble="true"/>
          <text_heading name="detailed_progress_pct" align="center"
                        bind_text="print_status_progress_pct" clickable="false" event_bubble="true"/>
        </lv_obj>
        <!-- Temps under arc/data when colspan>=3 -->
        <lv_obj name="detailed_temp_row_under_data"
                width="100%" height="content" style_pad_all="0" flex_flow="row"
                style_pad_gap="#space_sm" scrollable="false" clickable="false" event_bubble="true">
          <bind_flag_if_eq subject="print_status_temp_under_thumb" flag="hidden" ref_value="1"/>
          <nozzle_temp_block/>
          <bed_temp_block/>
          <chamber_temp_block/>
        </lv_obj>
      </lv_obj>
      <lv_obj name="detailed_data_col"
              flex_grow="1" height="100%" style_pad_all="0" flex_flow="column"
              style_flex_main_place="space_evenly" style_pad_gap="#space_xxs"
              scrollable="false" clickable="false" event_bubble="true">
        <text_body name="detailed_filename" width="100%"
                   bind_text="print_display_filename" long_mode="scroll_circular"
                   clickable="false" event_bubble="true"/>
        <text_small bind_text="print_status_layer_text" clickable="false" event_bubble="true"/>
        <text_small bind_text="print_status_time_text" clickable="false" event_bubble="true"/>
        <text_small bind_text="print_status_filament_text" clickable="false" event_bubble="true">
          <bind_flag_if_eq subject="print_status_show_filament_active" flag="hidden" ref_value="0"/>
        </text_small>
      </lv_obj>
    </lv_obj>
    <!-- Temps full-width when colspan==2 -->
    <lv_obj name="detailed_temp_row_full"
            width="100%" height="content" style_pad_all="0" flex_flow="row"
            style_pad_gap="#space_md" style_flex_main_place="space_around"
            scrollable="false" clickable="false" event_bubble="true">
      <bind_flag_if_eq subject="print_status_temp_under_thumb" flag="hidden" ref_value="0"/>
      <nozzle_temp_block/>
      <bed_temp_block/>
      <chamber_temp_block/>
    </lv_obj>
    <!-- M117 footer -->
    <text_small name="detailed_active_display_message" width="100%"
                bind_text="display_message" style_text_align="center" long_mode="dots"
                hidden="true" clickable="false" event_bubble="true">
      <bind_flag_if_eq subject="display_message_visible" flag="hidden" ref_value="0"/>
    </text_small>
  </view>

  <!-- Idle hero -->
  <view name="print_status_detailed_idle" extends="lv_obj"
        width="100%" height="100%" style_pad_all="0" style_pad_gap="#space_xs"
        flex_flow="column" scrollable="false" clickable="false" event_bubble="true">
    <lv_obj name="idle_main_row"
            width="100%" flex_grow="1" style_pad_all="0" flex_flow="row" style_pad_gap="#space_sm"
            scrollable="false" clickable="false" event_bubble="true">
      <lv_image name="idle_thumb"
                width="45%" height="100%" src="A:assets/images/benchy_thumbnail_white.png"
                inner_align="contain" clickable="false" event_bubble="true"/>
      <lv_obj name="idle_data_col"
              flex_grow="1" height="100%" style_pad_all="0" flex_flow="column"
              style_flex_main_place="center" style_pad_gap="#space_xs"
              scrollable="false" clickable="false" event_bubble="true">
        <text_body bind_text="print_status_idle_filename" long_mode="scroll_circular"
                   width="100%" clickable="false" event_bubble="true"/>
        <text_small bind_text="print_status_idle_when" style_text_color="#text_muted"
                    clickable="false" event_bubble="true"/>
        <text_small bind_text="print_status_idle_meta" style_text_color="#text_muted"
                    clickable="false" event_bubble="true"/>
        <ui_button name="idle_reprint_btn" width="content" height="#button_height_sm"
                   variant="outline" text="Reprint Last" translation_tag="Reprint Last">
          <bind_state_if_eq subject="print_status_idle_has_last" state="disabled" ref_value="0"/>
          <event_cb trigger="clicked" callback="library_last_cb"/>
        </ui_button>
      </lv_obj>
    </lv_obj>
    <text_small name="detailed_idle_display_message" width="100%"
                bind_text="display_message" style_text_align="center" long_mode="dots"
                hidden="true" clickable="false" event_bubble="true">
      <bind_flag_if_eq subject="display_message_visible" flag="hidden" ref_value="0"/>
    </text_small>
  </view>
</component>
