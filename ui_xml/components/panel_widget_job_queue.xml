<component>
  <view extends="lv_obj"
        width="100%" height="100%" style_pad_all="#space_sm" style_pad_gap="#space_xs"
        style_bg_opa="0%" scrollable="false"
        flex_flow="column" style_flex_main_place="start" style_flex_cross_place="start">

    <event_cb trigger="clicked" callback="on_job_queue_widget_clicked"/>

    <!-- Header row: icon + title + state badge -->
    <lv_obj width="100%" height="content" flex_flow="row"
            style_flex_main_place="start" style_flex_cross_place="center"
            style_pad_gap="#space_sm" style_bg_opa="0%" style_border_width="0"
            style_pad_all="0" clickable="false" event_bubble="true">
      <icon src="progress_clock" size="#icon_size" variant="secondary" event_bubble="true"/>
      <text_heading text="Job Queue" flex_grow="1" translation_tag="Job Queue" event_bubble="true"/>
      <text_small bind_text="job_queue_state_text" event_bubble="true"/>
    </lv_obj>

    <!-- Summary text -->
    <text_body bind_text="job_queue_summary_text" event_bubble="true"/>

    <!-- Job list container (scrollable, populated dynamically) -->
    <!-- Hidden in compact mode (size_mode == 0) -->
    <lv_obj name="job_list_container" width="100%" flex_grow="1"
            flex_flow="column" style_pad_all="0" style_pad_gap="2"
            style_bg_opa="0%" style_border_width="0"
            scrollbar_mode="auto" overflow="scroll"
            clickable="false" event_bubble="true">
      <bind_flag_if_eq subject="jq_size_mode" flag="hidden" ref_value="0"/>
    </lv_obj>

    <!-- Empty state (visibility controlled by rebuild_job_list) -->
    <text_small name="jq_empty_state" text="No jobs in queue"
                style_text_align="center" width="100%" translation_tag="No jobs in queue"
                hidden="true" event_bubble="true"/>
  </view>
</component>
