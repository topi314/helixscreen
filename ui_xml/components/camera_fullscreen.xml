<component>
  <view name="camera_fullscreen"
        width="100%" height="100%"
        style_bg_color="#screen_bg" style_bg_opa="255"
        style_radius="0" style_border_width="0"
        scrollbar_mode="off" style_clip_corner="true">
    <lv_image name="fullscreen_camera_image" width="100%" height="100%"
              clickable="false" event_bubble="true"/>
    <!-- "Connecting…" indicator centered on screen; hidden on first frame -->
    <lv_obj name="fullscreen_spinner"
            align="center" floating="true"
            width="content" height="content"
            style_bg_opa="0" style_border_width="0" style_pad_all="#space_md"
            flex_flow="column" style_flex_cross_place="center"
            style_flex_main_place="center" style_pad_gap="#space_md"
            clickable="false" event_bubble="true" scrollable="false">
      <spinner size="lg"/>
      <text_body text="Connecting Camera..." translation_tag="Connecting Camera..."
                 style_text_align="center"/>
    </lv_obj>
    <lv_obj name="fullscreen_close_btn"
            align="top_right" floating="true"
            width="#button_height" height="#button_height"
            style_translate_x="-24" style_translate_y="16"
            style_bg_color="#card_bg" style_bg_opa="120"
            style_radius="#border_radius" style_border_width="0">
      <event_cb trigger="clicked" callback="on_camera_fullscreen_close"/>
      <icon src="close" size="lg" style_text_color="#text"
            align="center"
            clickable="false" event_bubble="true"/>
    </lv_obj>
  </view>
</component>
