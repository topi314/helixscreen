<component>
  <api>
    <!-- Font size: "sm" (small), "md" (medium/default), "lg" (large/heading) -->
    <prop name="size" type="string" default="md"/>
    <!-- Show the "/ target" portion (opt-in, hidden by default) -->
    <prop name="show_target" type="string" default="false"/>
    <!-- Subject name for current temperature (int, centidegrees) -->
    <prop name="bind_current" type="string" default=""/>
    <!-- Subject name for target temperature (int, centidegrees) -->
    <prop name="bind_target" type="string" default=""/>
    <!-- Optional click callback name (makes widget clickable when set) -->
    <prop name="event_cb" type="string" default=""/>
    <!-- Responsive: hide separator+target below this breakpoint.
         Accepts: micro|tiny|small|medium|large|xlarge|xxlarge.
         Empty (default) = always show when show_target=true. -->
    <prop name="hide_target_below_bp" type="string" default=""/>
  </api>
  <!--
    The temp_display widget is a custom C++ widget registered via ui_temp_display_init().
    It creates a row of labels: [current] [ / ] [target] [°C]
    The C++ implementation handles:
    - Font sizing based on "size" prop
    - Hiding separator/target when show_target="false"
    - Subject binding for reactive updates
    - text for temps, text_muted for separators
  -->
  <view name="temp_display_widget"
        extends="temp_display" size="$size" show_target="$show_target" bind_current="$bind_current"
        bind_target="$bind_target" event_cb="$event_cb" hide_target_below_bp="$hide_target_below_bp"/>
</component>
