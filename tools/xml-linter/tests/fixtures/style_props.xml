<?xml version="1.0"?>
<!-- File using style properties extensively -->
<component>
  <consts>
    <px name="space_md" value="12"/>
  </consts>
  <view name="style_view" extends="lv_obj" width="100%" height="100%"
        style_pad_all="#space_md" style_bg_opa="255" style_radius="8"
        style_border_width="1" style_border_color="#0xcccccc"
        style_text_font="#font_body" style_text_align="center"
        style_flex_main_place="center" style_flex_cross_place="start"
        style_pad_gap="#space_md" style_min_height="100"
        style_shadow_width="4" style_shadow_opa="50"
        style_clip_corner="true">
    <lv_label text="Styled" style_text_decor="underline"/>
  </view>
</component>
