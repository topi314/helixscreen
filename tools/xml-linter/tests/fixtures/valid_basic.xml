<?xml version="1.0"?>
<!-- Valid basic component -->
<component>
  <consts>
    <px name="pad" value="16"/>
    <string name="greeting" value="hello"/>
  </consts>
  <view name="my_view" extends="lv_obj" width="100%" height="content" flex_flow="column">
    <lv_obj width="100%" height="50" style_bg_color="0xff0000" style_bg_opa="255" style_radius="8">
      <lv_label text="Hello World" long_mode="wrap"/>
    </lv_obj>
    <lv_button width="100" height="40" style_bg_color="0x00ff00">
      <lv_label text="Click Me"/>
    </lv_button>
  </view>
</component>
