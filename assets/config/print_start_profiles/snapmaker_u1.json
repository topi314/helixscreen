{
  "name": "Snapmaker U1",
  "description": "Snapmaker U1 — matches real gcode_response strings emitted by the firmware during PRINT_START. Verified against live capture 2026-05-19. The Snapmaker U1 PRINT_START gcode_macro is essentially empty — all preprint phases (homing, heating, leveling, plate detection, cleaning, purging) are driven by the slicer-injected gcode running on a custom Klipper build that emits action-code transitions via SET_ACTION_CODE.",
  "progress_mode": "weighted",
  "signal_formats": [
    {
      "prefix": "// Success: Set action code ",
      "mappings": {
        "BED_PREHEATING":        { "phase": "HEATING_BED",    "message": "Heating Bed..." },
        "BED_PRESCANNING":       { "phase": "BED_MESH",       "message": "Pre-scanning Bed..." },
        "BED_LEVELING":          { "phase": "BED_MESH",       "message": "Levelling Bed..." },
        "DETECT_PLATE":          { "phase": "BED_MESH",       "message": "Detecting Plate..." },
        "PRINT_BED_DETECTING":   { "phase": "BED_MESH",       "message": "Inspecting Bed..." },
        "PRINT_SWITCH_CHECKING": { "phase": "INITIALIZING",   "message": "Checking Extruder..." },
        "PRINT_RESUMING":        { "phase": "INITIALIZING",   "message": "Resuming Print..." },
        "PRINT_REPLENISHING":    { "phase": "INITIALIZING",   "message": "Replenishing Filament..." },
        "PRINT_PREEXTRUDING":    { "phase": "PURGING",        "message": "Pre-extruding..." }
      }
    }
  ],
  "response_patterns": [
    { "pattern": "^// trigger_mcu_pos: \\{",   "phase": "HOMING",   "message": "Homing...",         "weight": 8  },
    { "pattern": "^// probe_start_x: ",         "phase": "BED_MESH", "message": "Z Calibration...",  "weight": 5  }
  ],
  "silent_progression": [
    { "after_temps_ready_seconds": 0,  "phase": "CLEANING", "message": "Cleaning Nozzle..." },
    { "after_temps_ready_seconds": 12, "phase": "PURGING",  "message": "Purging..." }
  ],
  "phase_weights": {
    "HOMING": 5,
    "HEATING_BED": 25,
    "HEATING_NOZZLE": 20,
    "BED_MESH": 35,
    "CLEANING": 5,
    "PURGING": 5,
    "INITIALIZING": 5
  }
}
