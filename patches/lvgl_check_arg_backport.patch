+++ b/src/misc/lv_check_arg.h
@@ -0,0 +1,97 @@
+/**
+ * @file lv_check_arg.h
+ *
+ * HelixScreen backport of LVGL master's LV_CHECK_ARG argument-check macro into
+ * the pinned v9.5.0 tree. Master ships this at
+ * include/lvgl/debugging/lv_check_arg.h and exposes it globally via the public
+ * header tree. v9.5.0 has no equivalent, so we vendor a self-contained copy and
+ * pull it in from lv_assert.h.
+ *
+ * Drop this file (plus the lv_assert.h include and the mk/patches.mk wiring)
+ * when lib/lvgl is bumped past v9.5.0 — upstream provides it natively.
+ */
+
+#ifndef LV_CHECK_ARG_H
+#define LV_CHECK_ARG_H
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+/*********************
+ *      INCLUDES
+ *********************/
+#include "lv_log.h"
+
+/*********************
+ *      DEFINES
+ *********************/
+
+/* Master gates these via lv_conf; default them here so no lv_conf changes are
+ * required on v9.5.0. Set LV_USE_CHECK_ARG to 0 in lv_conf.h to compile the
+ * checks out entirely. */
+#ifndef LV_USE_CHECK_ARG
+#  define LV_USE_CHECK_ARG 1
+#endif
+
+#ifndef LV_LIKELY
+#  if defined(__GNUC__) || defined(__clang__)
+#    define LV_LIKELY(x)   (__builtin_expect(!!(x), 1))
+#  else
+#    define LV_LIKELY(x)   (x)
+#  endif
+#endif
+
+#ifndef LV_UNLIKELY
+#  if defined(__GNUC__) || defined(__clang__)
+#    define LV_UNLIKELY(x) (__builtin_expect(!!(x), 0))
+#  else
+#    define LV_UNLIKELY(x) (x)
+#  endif
+#endif
+
+/**********************
+ *      MACROS
+ **********************/
+
+#if LV_USE_CHECK_ARG
+
+/* Internal — do not use directly; use LV_CHECK_ARG. */
+#  define LV_CHECK_ARG_INTERNAL_(cond, cond_str, action_on_fail, ...)  \
+    if(LV_UNLIKELY(!(cond))) {                                          \
+        LV_LOG_WARN("Check failed: " cond_str " " __VA_ARGS__);        \
+        action_on_fail;                                                 \
+    } else {}
+
+#else
+
+#  define LV_CHECK_ARG_INTERNAL_(cond, cond_str, action_on_fail, ...) ((void)0)
+
+#endif /*LV_USE_CHECK_ARG*/
+
+/**
+ * Check that a condition is true. If the condition is false, log a warning and
+ * execute `action_on_fail` (e.g. `return`, `return val`, `break`). Optional
+ * printf-style arguments are appended to the log message.
+ *
+ * Can be disabled by setting LV_USE_CHECK_ARG to 0 in lv_conf.h. Log output
+ * requires LV_USE_LOG; with LV_USE_LOG 0 no output is produced.
+ *
+ * Example:
+ * @code
+ * LV_CHECK_ARG(ptr != NULL, return, "pointer must not be NULL");
+ * LV_CHECK_ARG(len > 0, return -1, "len=%d", (int)len);
+ * @endcode
+ *
+ * @param cond              condition to check
+ * @param action_on_fail    statement to execute on failure (e.g. `return`, `return false`)
+ * @param ...               optional printf-style format string and arguments for the log
+ */
+#define LV_CHECK_ARG(cond, action_on_fail, ...)                        \
+    LV_CHECK_ARG_INTERNAL_(cond, #cond, action_on_fail, __VA_ARGS__)
+
+#ifdef __cplusplus
+} /*extern "C"*/
+#endif
+
+#endif /*LV_CHECK_ARG_H*/
